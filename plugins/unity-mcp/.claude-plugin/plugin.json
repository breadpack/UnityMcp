{
  "name": "unity-mcp",
  "description": "AI 에이전트가 Unity Editor를 제어하는 MCP 브릿지 — 씬 편집, 에셋 관리, 빌드 자동화",
  "version": "0.3.0",
  "author": {
    "name": "breadpack",
    "url": "https://github.com/breadpack"
  },
  "homepage": "https://github.com/breadpack/UnityMcp",
  "repository": "https://github.com/breadpack/UnityMcp",
  "license": "MIT",
  "keywords": ["unity", "mcp", "gamedev", "editor", "scene", "build"],
  "mcpServers": {
    "unity-bridge": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/run-bridge.js"]
    }
  },
  "userConfig": {
    "unity_tcp_port": {
      "type": "number",
      "title": "Unity TCP Port",
      "description": "Unity Editor가 대기할 TCP 포트 (기본: 9876)",
      "default": 9876,
      "sensitive": false
    },
    "auto_save_scene": {
      "type": "boolean",
      "title": "Auto Save Scene",
      "description": "씬 변경 후 자동 저장 여부 (기본: false)",
      "default": false,
      "sensitive": false
    },
    "check_compile_status": {
      "type": "boolean",
      "title": "Check Compile Status",
      "description": "도구 호출 전 컴파일 상태 체크 여부 (기본: true)",
      "default": true,
      "sensitive": false
    },
    "check_domain_reload": {
      "type": "boolean",
      "title": "Check Domain Reload",
      "description": "도구 호출 전 도메인 리로드 상태 체크 여부 (기본: true)",
      "default": true,
      "sensitive": false
    },
    "max_wait_seconds": {
      "type": "number",
      "title": "Max Wait Seconds",
      "description": "컴파일/리로드 대기 최대 시간(초, 기본: 60)",
      "default": 60,
      "sensitive": false
    }
  }
}
