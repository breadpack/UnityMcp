{
  "description": "Unity MCP lifecycle hooks — connection check, compile/reload wait, auto-save, failure diagnosis",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/check-unity.js --mode=session-start"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__unity-bridge__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/check-unity.js --mode=pre-tool --check-compile=${userConfig.check_compile_status} --check-reload=${userConfig.check_domain_reload}"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__unity-bridge__(unity_create_gameobject|unity_delete_gameobject|unity_add_component|unity_remove_component|unity_set_property|unity_set_transform|unity_reparent_gameobject|unity_instantiate_prefab)",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/post-tool-check.js --auto-save=${userConfig.auto_save_scene}"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "mcp__unity-bridge__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/check-unity.js --mode=failure-diagnosis"
          }
        ]
      }
    ]
  }
}
